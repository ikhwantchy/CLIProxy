# Environment configuration for CLIProxyAPI
# Dibuat otomatis untuk deployment api.sendr.web.id

# Management key (harus sama dengan secret-key di config.yaml jika ingin via env)
# MANAGEMENT_PASSWORD=sendr123

# Port Mapping (Docker)
CLI_PROXY_PORT=8317
CLI_PROXY_CONFIG_PATH=./config.yaml
